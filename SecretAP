local function createPlayerEntry(player, colorIdx)
	local entry = Instance.new("TextButton")
	entry.Name = player.Name
	entry.Size = UDim2.new(1, 0, 0, 26)
	entry.BackgroundTransparency = 1
	entry.Text = ""
	entry.Parent = PlayerList

	local avatarCircle = Instance.new("Frame")
	avatarCircle.Size = UDim2.new(0, 20, 0, 20)
	avatarCircle.Position = UDim2.new(0, 2, 0.5, -10)
	avatarCircle.BackgroundColor3 = avatarColors[colorIdx % #avatarColors + 1]
	avatarCircle.BorderSizePixel = 0
	avatarCircle.Parent = entry

	local avatarCorner = Instance.new("UICorner")
	avatarCorner.CornerRadius = UDim.new(1, 0)
	avatarCorner.Parent = avatarCircle

	local initial = Instance.new("TextLabel")
	initial.Text = string.upper(string.sub(player.Name, 1, 1))
	initial.Font = Enum.Font.GothamBold
	initial.TextSize = 10
	initial.TextColor3 = Color3.fromRGB(255, 255, 255)
	initial.BackgroundTransparency = 1
	initial.Size = UDim2.new(1, 0, 1, 0)
	initial.Parent = avatarCircle

	local nameLabel = Instance.new("TextLabel")
	nameLabel.Text = player.Name
	nameLabel.Font = Enum.Font.GothamBold
	nameLabel.TextSize = 10
	nameLabel.TextColor3 = Color3.fromRGB(205, 214, 244)
	nameLabel.BackgroundTransparency = 1
	nameLabel.Size = UDim2.new(1, -28, 1, 0)
	nameLabel.Position = UDim2.new(0, 26, 0, 0)
	nameLabel.TextXAlignment = Enum.TextXAlignment.Left
	nameLabel.TextTruncate = Enum.TextTruncate.AtEnd
	nameLabel.Parent = entry

	entry.MouseButton1Click:Connect(function()
		selectedPlayerName = player.Name
		for _, e in pairs(playerEntries) do
			e.BackgroundTransparency = 1
		end
		entry.BackgroundTransparency = 0
		entry.BackgroundColor3 = Color3.fromRGB(15, 52, 96)
		TargetDisplay.Text = player.Name
	end)

	entry.MouseEnter:Connect(function()
		if selectedPlayerName ~= player.Name then
			entry.BackgroundTransparency = 0
			entry.BackgroundColor3 = Color3.fromRGB(30, 45, 94)
		end
	end)

	entry.MouseLeave:Connect(function()
		if selectedPlayerName ~= player.Name then
			entry.BackgroundTransparency = 1
		end
	end)

	return entry
end

local function refreshPlayerList()
	for _, child in pairs(PlayerList:GetChildren()) do
		if child:IsA("GuiObject") then child:Destroy() end
	end
	playerEntries = {}
	local i = 0
	for _, player in ipairs(Players:GetPlayers()) do
		local entry = createPlayerEntry(player, i)
		playerEntries[player.Name] = entry
		i = i + 1
	end
end

Players.PlayerAdded:Connect(refreshPlayerList)
Players.PlayerRemoving:Connect(refreshPlayerList)
refreshPlayerList()

