local function showToast(msg)
	Toast.Text = msg
	Toast.BackgroundTransparency = 0
	Toast.Visible = true
	TweenService:Create(Toast, TweenInfo.new(0.3), {BackgroundTransparency = 0}):Play()
	task.delay(2, function()
		TweenService:Create(Toast, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
		task.delay(0.35, function()
			Toast.Visible = false
		end)
	end)
end

local function executeCommand()
	local cmd = CmdInput.Text:lower():gsub("%s+", "")
	if cmd == "" then
		showToast("⚠ Kein Befehl eingegeben!")
		return
	end
	if selectedPlayerName == "" then
		showToast("⚠ Kein Spieler ausgewählt!")
		return
	end

	local target = Players:FindFirstChild(selectedPlayerName)
	if not target then
		showToast("⚠ Spieler nicht gefunden!")
		return
	end

	local char = target.Character
	local humanoid = char and char:FindFirstChildOfClass("Humanoid")

	if cmd == ":rocket" then
		if char and char:FindFirstChild("HumanoidRootPart") then
			local bv = Instance.new("BodyVelocity")
			bv.Velocity = Vector3.new(0, 200, 0)
			bv.MaxForce = Vector3.new(0, math.huge, 0)
			bv.Parent = char.HumanoidRootPart
			game:GetService("Debris"):AddItem(bv, 0.5)
		end
	elseif cmd == ":ragdoll" then
		if humanoid then
			humanoid.PlatformStand = not humanoid.PlatformStand
		end
	elseif cmd == ":balloon" then
		if char and char:FindFirstChild("HumanoidRootPart") then
			local bg = Instance.new("BodyGyro")
			bg.MaxTorque = Vector3.new(0, 0, 0)
			bg.Parent = char.HumanoidRootPart
			local bv = Instance.new("BodyVelocity")
			bv.Velocity = Vector3.new(0, 5, 0)
			bv.MaxForce = Vector3.new(0, 3000, 0)
			bv.Parent = char.HumanoidRootPart
			game:GetService("Debris"):AddItem(bv, 5)
			game:GetService("Debris"):AddItem(bg, 5)
		end
	elseif cmd == ":inverse" then
		if char then
			for _, part in pairs(char:GetDescendants()) do
				if part:IsA("BasePart") then
					part.CFrame = part.CFrame * CFrame.Angles(math.pi, 0, 0)
				end
			end
		end
	elseif cmd == ":nightvision" then
		local lighting = game:GetService("Lighting")
		lighting.Brightness = lighting.Brightness == 0 and 2 or 0
	elseif cmd == ":jail" then
		if char and char:FindFirstChild("HumanoidRootPart") then
			local jail = Instance.new("Part")
			jail.Size = Vector3.new(6, 8, 6)
			jail.Anchored = true
			jail.Transparency = 0.5
			jail.BrickColor = BrickColor.new("Dark grey")
			jail.Position = char.HumanoidRootPart.Position
			jail.Parent = workspace
			game:GetService("Debris"):AddItem(jail, 10)
		end
	elseif cmd == ":control" then
		showToast("🎮 Control: " .. selectedPlayerName)
	elseif cmd == ":tiny" then
		if char then
			local hrp = char:FindFirstChild("HumanoidRootPart")
			if hrp then
				char:ScaleTo(0.25)
			end
			if humanoid then
				humanoid.WalkSpeed = 8
			end
		end
	elseif cmd == ":jumpscare" then
		if target == LocalPlayer then
			local jumpGui = Instance.new("ScreenGui")
			jumpGui.Parent = PlayerGui
			local jumpFrame = Instance.new("Frame")
			jumpFrame.Size = UDim2.new(1, 0, 1, 0)
			jumpFrame.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
			jumpFrame.BackgroundTransparency = 0
			jumpFrame.ZIndex = 100
			jumpFrame.Parent = jumpGui
			local jumpLabel = Instance.new("TextLabel")
			jumpLabel.Text = "BOO! 👻"
			jumpLabel.Font = Enum.Font.GothamBold
			jumpLabel.TextSize = 80
			jumpLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
			jumpLabel.Size = UDim2.new(1, 0, 1, 0)
			jumpLabel.BackgroundTransparency = 1
			jumpLabel.ZIndex = 101
			jumpLabel.Parent = jumpGui
			game:GetService("Debris"):AddItem(jumpGui, 1.5)
		end
	elseif cmd == ":morph" then
		if char then
			for _, part in pairs(char:GetDescendants()) do
				if part:IsA("BasePart") then
					part.BrickColor = BrickColor.Random()
				end
			end
		end
	else
		showToast("❓ Unbekannter Befehl: " .. cmd)
		return
	end

	showToast("✓ " .. cmd .. " → " .. selectedPlayerName)
end

local panelOpen = false
local function togglePanel()
	panelOpen = not panelOpen
	if panelOpen then
		MainFrame.Visible = true
		MainFrame.Size = UDim2.new(0, 0, 0, 0)
		MainFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
		TweenService:Create(MainFrame, TweenInfo.new(0.25, Enum.EasingStyle.Back), {
			Size = UDim2.new(0, 340, 0, 300),
			Position = UDim2.new(0.5, -170, 0.5, -150)
		}):Play()
	else
		TweenService:Create(MainFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
			Size = UDim2.new(0, 0, 0, 0),
			Position = UDim2.new(0.5, 0, 0.5, 0)
		}):Play()
		task.delay(0.22, function()
			MainFrame.Visible = false
		end)
	end
end

